<h2 class="text-2xl font-bold mb-6 text-center">新規登録</h2>

<div class="max-w-md mx-auto bg-white p-6 rounded-lg shadow">
  <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>

    <!-- エラーメッセージ -->
    <%= render "devise/shared/error_messages", resource: resource %>

    <!-- メールアドレス -->
    <div class="mb-4">
      <%= f.label :email, "メールアドレス", class: "block mb-1 font-medium" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email",
            class: "w-full border rounded px-3 py-2 focus:ring focus:ring-blue-200" %>
    </div>

    <!-- パスワード -->
    <div class="mb-4">
      <%= f.label :password, "パスワード", class: "block mb-1 font-medium" %>

      <% if @minimum_password_length %>
        <p class="text-sm text-gray-600 mb-1">
          （最低 <%= @minimum_password_length %> 文字）
        </p>
      <% end %>

      <%= f.password_field :password, autocomplete: "new-password",
            class: "w-full border rounded px-3 py-2 focus:ring focus:ring-blue-200" %>
    </div>

    <!-- パスワード確認 -->
    <div class="mb-4">
      <%= f.label :password_confirmation, "パスワード（確認）", class: "block mb-1 font-medium" %>
      <%= f.password_field :password_confirmation, autocomplete: "new-password",
            class: "w-full border rounded px-3 py-2 focus:ring focus:ring-blue-200" %>
    </div>

    <!-- 登録ボタン -->
    <%= f.submit "登録する",
          class: "w-full bg-green-600 text-white py-2 rounded hover:bg-green-700 transition" %>

  <% end %>

  <!-- ログインリンク -->
  <div class="mt-4 text-center">
    <%= render "devise/shared/links" %>
  </div>
</div>
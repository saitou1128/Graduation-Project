<h2 class="text-2xl font-bold mb-6 text-center">ログイン</h2>

<div class="max-w-md mx-auto bg-white p-6 rounded-lg shadow">
  <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>

    <!-- メールアドレス -->
    <div class="mb-4">
      <%= f.label :email, "メールアドレス", class: "block mb-1 font-medium" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email",
            class: "w-full border rounded px-3 py-2 focus:ring focus:ring-blue-200" %>
    </div>

    <!-- パスワード -->
    <div class="mb-4">
      <%= f.label :password, "パスワード", class: "block mb-1 font-medium" %>
      <%= f.password_field :password, autocomplete: "current-password",
            class: "w-full border rounded px-3 py-2 focus:ring focus:ring-blue-200" %>
    </div>

    <!-- ログイン状態を保持する -->
    <% if devise_mapping.rememberable? %>
      <div class="flex items-center mb-4">
        <%= f.check_box :remember_me, class: "mr-2" %>
        <%= f.label :remember_me, "ログイン状態を保持する" %>
      </div>
    <% end %>

    <!-- ログインボタン -->
    <%= f.submit "ログイン",
          class: "w-full bg-blue-600 text-white py-2 rounded hover:bg-blue-700 transition" %>
  <% end %>

  <!-- パスワード再発行・新規登録リンク -->
  <div class="mt-4 text-center">
    <%= render "devise/shared/links" %>
  </div>
</div>
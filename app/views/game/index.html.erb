<div class="mt-10 flex flex-wrap items-center gap-3 justify-center">
  <% @stations.each_with_index do |station, index| %>
    <% is_current = (station.id == @current_station.id) %>
    <% is_next = (@next_station && station.id == @next_station.id) %>
    <% has_stamp = @stamp_stations.include?(station.id) %>

    <div class="flex flex-col items-center">

      <!-- ▼ラベル -->
      <div class="h-4 mb-1 flex items-center justify-center text-xs">
        <% if is_current %>
          <span class="text-yellow-600">▼ 現在の駅</span>
        <% elsif is_next %>
          <span class="text-blue-600">▼ 次の駅</span>
        <% end %>
      </div>

      <!-- 駅アイコン -->
      <div class="w-14 h-14 min-h-14 max-h-14
            flex items-center justify-center
            rounded-full border flex-shrink-0
            text-[10px] font-semibold text-center
            leading-none whitespace-normal break-words
            overflow-hidden
            <%= if is_current
                  'bg-yellow-300 border-yellow-500 ring-4 ring-yellow-400'
                elsif is_next
                  'bg-blue-300 border-blue-600 ring-2 ring-blue-400'
                else
                  'bg-green-100 border-green-400'
                end %>">
        <%= station.name %>
      </div>

      <!-- ⭐ スタンプ取得済みマーク -->
      <% if has_stamp %>
        <div class="text-green-600 text-xs mt-1 font-semibold">⭐ GET!</div>
      <% end %>

    </div>

    <% unless index == @stations.size - 1 %>
      <div class="w-10 h-1 bg-gray-300"></div>
    <% end %>
  <% end %>
</div>

<div class="mt-8 grid grid-cols-1 md:grid-cols-2 gap-6 items-stretch">

  <div class="p-4 bg-white shadow rounded h-full flex flex-col justify-between">

    <!-- サイコロを振る -->
    <div class="mb-4 text-left">
      <% can_roll = @game_state.mission_cleared && @game_state.last_dice_result.nil? %>

      <%= button_to "サイコロを振る", game_roll_path, method: :post,
            class: "px-4 py-2 rounded w-48 mx-auto text-center transition transform
                    #{ can_roll ? 'bg-blue-500 text-white hover:scale-105 active:scale-95' :
                                   'bg-gray-300 text-gray-500 cursor-not-allowed' }",
            disabled: !can_roll %>
    </div>

    <!-- サイコロ結果 -->
    <% if @game_state.last_dice_result.present? %>
      <div class="mb-4 flex items-center gap-2 text-left">
        <span class="text-sm font-semibold">サイコロの結果：</span>
        <div class="w-10 h-10 flex items-center justify-center bg-gray-100 border rounded text-xl">
          <%= @game_state.last_dice_result %>
        </div>
      </div>
    <% end %>

    <!-- 次の駅 -->
    <% if @next_station.present? %>
      <div class="mb-4 text-sm text-blue-600 font-semibold text-left">
        次の駅：<%= @next_station.name %>
      </div>
    <% end %>

    <!-- 進む -->
    <div class="mt-auto text-left">
      <% if user_signed_in? %>
        <% can_move = @game_state.last_dice_result.present? && @game_state.mission_cleared %>
      <% else %>
        <% can_move = @game_state.last_dice_result.present? %>
      <% end %>
      <%= button_to "進む", game_move_path, method: :post,
            class: "px-4 py-2 rounded w-48 mx-auto text-center transition transform
                    #{ can_move ? 'bg-green-500 text-white hover:scale-105 active:scale-95' :
                                  'bg-gray-300 text-gray-500 cursor-not-allowed' }",
            disabled: !can_move %>
    </div>
  </div>

  <div class="p-4 bg-white shadow rounded h-full flex flex-col justify-between">

    <!-- 現在の駅 -->
    <div class="flex justify-between items-center mb-3">
      <h2 class="text-lg font-bold text-left">
        現在の駅：<%= @current_station.name %>
      </h2>

      <% if @stamp_stations.include?(@current_station.id) %>
        <div class="text-green-600 text-sm font-semibold ml-3">
          ⭐ GET!
        </div>
      <% end %>
    </div>

    <!-- ミッション -->
    <p class="text-sm text-gray-700 mb-4 text-left">
      ミッション：<%= @mission&.content || "ミッションはありません" %>
    </p>

    <!-- ミッションクリア -->
    <% if user_signed_in? %>
      <% can_mission_complete = @mission.present? && !@game_state.mission_cleared %>
      <%= button_to "ミッションクリア！", game_mission_complete_path, method: :post,
            class: "px-4 py-2 rounded w-48 mx-auto text-center transition transform
                    #{ can_mission_complete ?
                       'bg-purple-500 text-white hover:scale-105 active:scale-95' :
                       'bg-gray-300 text-gray-500 cursor-not-allowed' }",
            disabled: !can_mission_complete %>
    <% else %>
      <!-- 未ログイン時-->
      <div class="text-left">
        <button
          class="px-4 py-2 rounded w-80 text-center bg-gray-300 text-gray-500 cursor-not-allowed">
          ミッションクリア（ログインが必要）
        </button>

        <div class="mt-2">
          <%= link_to "ログインしてスタンプをゲット！", new_user_session_path,
                class: "text-blue-600 underline text-sm font-semibold" %>
        </div>
      </div>
    <% end %>

    <!-- ゲームルール -->
    <div class="mt-4 p-3 bg-gray-50 border rounded text-xs text-gray-600 leading-relaxed">
      <p class="font-semibold text-gray-700 mb-1">【ゲームルール】</p>
      <ul class="list-disc ml-4 space-y-1">
        <li>ミッションをクリアするとサイコロが振れます</li>
        <li>サイコロを振り進むボタンを押すと次の駅へ進みます</li>
        <li>スタンプを取得した駅はカウントしません。</li>
      </ul>
    </div>
  </div>

</div>
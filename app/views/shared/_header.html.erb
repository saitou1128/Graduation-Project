<header class="flex justify-between items-center px-6 py-4 bg-[#9acd32] shadow">
  <div>
    <%= link_to game_path, class: "text-2xl font-extrabold text-white tracking-wide hover:opacity-80 transition" do %>
      山手線すごろく
    <% end %>
  </div>

  <nav class="flex items-center gap-4">
    <% if user_signed_in? %>

      <!-- スタンプ帳ボタン -->
      <%= link_to "📕 スタンプ帳", stamps_path,
            class: "px-4 py-2 bg-red-500 text-white rounded shadow hover:bg-red-600 transition text-sm font-semibold" %>

      <!-- ログアウトボタン -->
      <%= link_to "ログアウト", destroy_user_session_path,
            method: :delete,
            class: "px-4 py-2 bg-gray-200 text-gray-800 rounded shadow hover:bg-gray-300 transition text-sm font-semibold" %>

    <% else %>

      <!-- ログイン／会員登録ボタン（青） -->
      <%= link_to "ログイン / 会員登録", new_user_session_path,
            class: "px-4 py-2 bg-blue-500 text-white rounded shadow hover:bg-blue-600 transition text-sm font-semibold" %>

    <% end %>
  </nav>
</header>
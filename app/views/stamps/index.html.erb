<h1 class="text-3xl font-extrabold text-center mb-8 tracking-wider
           text-red-600 drop-shadow-md">
  📕 スタンプ帳
</h1>

<div class="bg-amber-50 p-6 rounded-lg shadow-inner">

  <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
    <% @stations.each do |station| %>
      <% stamp = @stamps.find { |s| s.station_id == station.id } %>
      <% has_stamp = stamp.present? %>

      <div class="flex flex-col items-center">

        <% if has_stamp %>
          <div class="w-32 h-32 rounded-full border-[8px] border-red-500 bg-red-50 shadow-lg
                      flex flex-col items-center justify-center text-center
                      transform transition hover:scale-110 hover:-translate-y-1">
            <div class="text-base font-bold text-red-700 tracking-wide">
              <%= station.name %>
            </div>
            <div class="text-[11px] text-red-600 mt-1 px-1">
              <%= stamp.mission&.content || "ミッションなし" %>
            </div>
          </div>

          <div class="text-xs text-gray-600 mt-2">
            <%= stamp.created_at.strftime("%Y-%m-%d") %>
          </div>

        <% else %>
          <div class="w-32 h-32 rounded-full border-[8px] border-gray-300 bg-gray-100 opacity-40
                      flex items-center justify-center text-center">
            <div class="text-base font-bold text-gray-500">
              <%= station.name %>
            </div>
          </div>
        <% end %>

      </div>
    <% end %>
  </div>

</div>